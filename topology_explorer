        if element.get_attribute("disabled") is None:
            self.click_element(element, self.CONTEXT_WAIT_TIME)
            return True
        return False

    def disable_full_screen(self) -> bool:
        """
            click fullScreen action once if it is not disabled
            :return: return True if fullScreen is clicked
        """
        element = self.shadow_root_element(self.workspace, "ucs-button[icon='ucs:isnd-minimize']")
        if element.get_attribute("disabled") is None:
            self.click_element(element, self.CONTEXT_WAIT_TIME)
            return True
        return False
    
    def click_on_legend(self):
        """
            click legend details once if it is not disabled
            :return: return True if legend details is clicked
        """
        element = self.shadow_root_element(self.workspace, "ucs-button[icon='ucs:isnd-info-o']")
        if element.get_attribute("disabled") is None:
            self.click_element(element, self.CONTEXT_WAIT_TIME)
            return True
        return False

    def search_node(self, name: str):
        """
            1) open search dropdown once if it is not disabled
            2) search by device name
            3) select device to center it on workspace - optional
            :return: return True if device is selected
        """
