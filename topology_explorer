        # if element.get_attribute("disabled") is None:
        #     self.click_element(element, self.CONTEXT_WAIT_TIME)
        #     element = self.shadow_root_element(self.element, "ucs-dropdown-pro-max")
        #     return True
        self.common_info.log(
