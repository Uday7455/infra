    def __convert_filter_str_dict(self, filter_str: str) -> Dict:
        """
            convert filter string to dictionary

            :param filter_str: filter string to convert
            :return: filter dictionary
        """
        filter_str = filter_str.strip()
        if not filter_str:
            raise ValueNotSet("filter value cannot be empty")
        filter_fields = filter_str.split(":", 1)
        if not len(filter_fields) == 2:
            raise ValueNotSet("Filter string format should be key:value")
        key, input_value = filter_fields
        operator_pattern = r'^\s?(!=|eq|ne|[<>=]=?)\s(.*$)'
        match_result = re.match(operator_pattern, input_value)
        if match_result:
            operator = match_result.group(1)
            input_value = self.__remove_start_end_quotes(re.match(operator_pattern, input_value).group(2))
        else:
            operator = "contains"
        return {"key": key, "operator": operator, "value": input_value.strip()}

    def __convert_filters_dict_str(self, filters: List[Dict]) -> List[str]:
        """
            convert filtered dict values to string list

            :param filters: filters to convert
            :return: string list
        """
        filter_list = []
        for filter_map in filters:
            key = filter_map.get("key")
            value = filter_map.get("value", '')
            operator = filter_map.get("operator", '')
            unit = filter_map.get("unit", '')

            value = ", ".join(value) if isinstance(value, list) else value
            operator = '' if operator == 'contains' else f"{operator} "
            filter_list.append(f"{key}:{operator}{value}{unit}")
        return filter_list

    def __get_filter_dict(self, filter_str: Union[str, List[Union[str, Dict]], Dict]) -> List[Dict]:
        """
            return filter dictionary based on filter string

            :param filter_str: filter string to set
            :return: filter dictionary
        """
        filter_list = []
        if isinstance(filter_str, str):
            filter_list.append(self.__convert_filter_str_dict(filter_str))
        elif isinstance(filter_str, list):
            for filter_item in filter_str:
                if isinstance(filter_item, str):
                    filter_list.append(self.__convert_filter_str_dict(filter_item))
                elif isinstance(filter_item, dict):
                    filter_list.append(filter_item)
        elif isinstance(filter_str, dict):
            filter_list.append(filter_str)
        if not filter_list:
            raise ValueNotSet("filter_str must be either string, list or dictionary")
        return filter_list

    def __is_free_form_search(self, filter_str: Union[str, List, Dict]) -> bool:
        """
            check if filter string is free form search

            :param filter_str: filter string to set
            :return: True if filter string is free form search
        """
        return False if isinstance(filter_str, (list, dict)) else ":" not in filter_str

    def column_headers(self,
                       table_grid: Optional[WebElement] = None,
                       timeout: Optional[int] = None) -> List[str]:
        """
            return column headers of the table

            :param table_grid: table grid web element.
            :param timeout: time to wait for table to be loaded.

            :return: column headers of the table
        """

        if table_grid is None:
            table_grid = self._get_table_grid(timeout)

        elements = table_grid.find_elements(
            By.CSS_SELECTOR, "div#main div.UcsGrid-column.head")

        table_column_headers = []

        grouped_headers = set()
        for element in elements:
            if element.id not in grouped_headers:
                if "group" in element.get_attribute("class"):
                    # handle group header
                    group_header_text = element.find_element(By.CSS_SELECTOR, "div.UcsGrid-column-title").text
                    child_columns = element.find_elements(By.CSS_SELECTOR, "div.UcsGrid-column.head")
                    for column in child_columns:
                        grouped_headers.add(column.id)
                        table_column_headers.append(f"{group_header_text}.{column.text}")
                else:
                    # individual header
                    table_column_headers.append(self.get_text(element))

        return table_column_headers

    def _get_row_read_status(self, table_grid: WebElement) -> List[bool]:
        """
            Determine the read status of each row in the current page.
            A row is considered unread if it contains a blue dot indicator
            (a small span styled as a circle with the accent color).

            :param table_grid: table grid web element.
            :return: list of booleans, True if the row has been read, False if unread.
        """
        return util.get_row_read_status(self.driver, table_grid)

    def page_data(self,
                  page: Union[int, str, None] = None,
                  rows: Optional[List[int]] = None,
                  columns: Optional[List[str]] = None,
                  table_grid: Optional[WebElement] = None,
                  column_headers: Optional[List[str]] = None,
                  timeout: Optional[int] = None) -> List[Mapping[str, str]]:
        """
        Return one page of table rows as dicts keyed by column name.

        :param page: page number to read, or None for the current page.
        :param rows: row subset to read, or None for all rows on the page.
        :param columns: column names to read, or None for all columns.
        :param table_grid: optional cached grid element to avoid lookup.
        :param column_headers: optional cached headers to avoid lookup.
        :param timeout: seconds to wait for the grid to be ready.
        :return: list of row dicts; hierarchical tables (id hierarchicalTable) add _visible_row_index,
            _tree_depth, _tree_parent_row_index, and _tree_is_branch from the grid.
        """

        if page and self.page_number(timeout) != int(page):
            self.set_page_number(page, timeout)

        if table_grid is None:
            table_grid = self._get_table_grid(timeout)

        if column_headers is None:
            column_headers = self.column_headers(table_grid, timeout)

        table_body = table_grid.find_element(
            By.CSS_SELECTOR, "div#main > div.UcsGrid-body")

        if rows is None:
            rows = []

        if columns is None:
            columns = []
        else:
            # convert columns requested into index
            column_list = []
            for index, header in enumerate(column_headers):
                if header in columns:
                    column_list.append(index)
            columns = column_list

        # for those computed table, there will be no pagination header and for those tables
        # we cannot base on the grid idle state to determine if table is finished populating
        # hence for now, we will wait for period of time to make sure the len of data doesn't change
        # so we don't end up return partial table.
        pagination_ctx = self._get_pagination_context()
        is_pagination_hidden = pagination_ctx is None or pagination_ctx.is_hidden() is not None
        hierarchical = self._is_hierarchical_table()
        if is_pagination_hidden:
            # no pagination
            data, hierarchy = util.get_table_data(
                self.driver, table_body, rows, columns, hierarchical)
            max_interval = 0.2
            wait_time_gen = util.wait_time.generator(self.START_WAIT_TIME,
                                                     max_interval,
                                                     0.7)

            for i in wait_time_gen:
                new_data, _ = util.get_table_data(
                    self.driver, table_body, rows, columns, hierarchical)
                if len(data) != len(new_data):
                    raise ValueNotSet("table did not finish loading")
                time.sleep(i)

        else:
            data, hierarchy = util.get_table_data(
                self.driver, table_body, rows, columns, hierarchical)

        table_data = []
        for column_index, row_list in data.items():
            column_name = column_headers[int(column_index)]
            if len(table_data) == 0:
                # initialize the rtr list map
                for _ in row_list:
                    table_data.append({})
            for index, entry in enumerate(row_list):
                table_data[index][column_name] = entry

        # Enrich each row with read/unread status only for tables that support unread indicator.
        include_read_status = self._has_unread_flag()
        read_statuses = self._get_row_read_status(table_grid) if include_read_status else []
        for index, row_map in enumerate(table_data):
            if hierarchical:
                row_map["_visible_row_index"] = str(index)
                hi = hierarchy[index]
                row_map["_tree_depth"] = hi["depth"]
                row_map["_tree_parent_row_index"] = hi.get("parentRowIndex", "")
                row_map["_tree_is_branch"] = hi.get("isBranch", "false")
            if include_read_status:
                if index < len(read_statuses):
                    row_map["_is_read"] = read_statuses[index]
                else:
                    row_map["_is_read"] = True

        return table_data

    def all_data(self,
                 columns: Optional[List[str]] = None,
                 timeout: Optional[int] = None) -> List[Mapping[str, str]]:
        """
            return all page data of the table.

            :param columns: table columns to retrieve the data from.  If None, all columns will be retrieved.
            :param timeout: time to wait for table to be loaded.
            :return: data of given page of the table

        """

        table_grid = self._get_table_grid(timeout)
        column_headers = self.column_headers(table_grid, timeout)

        if self.page_number(timeout) > 1:
            self.first_page(timeout)

        total_pages = self.total_pages(timeout)

        table_data = []
        for _ in range(1, total_pages):
            for _ in range(5):
                try:
                    table_data.extend(self.page_data(columns=columns,
                                                     column_headers=column_headers, timeout=timeout))
                    break
                except exceptions.StaleElementReferenceException:
                    time.sleep(0.1)
            self.next_page(timeout)

        # read current page
        for _ in range(5):
            try:
                table_data.extend(self.page_data(columns=columns,
                                                 column_headers=column_headers, timeout=timeout))
                break
            except exceptions.StaleElementReferenceException:
                time.sleep(0.1)
        return table_data

    def select_all(self, timeout: int) -> None:
        """
            select all rows

            :param timeout: time to wait for table to be loaded.
            :return: None

        """
        table_grid = self._get_table_grid(timeout)
        checkbox = table_grid.find_element(
            By.CSS_SELECTOR, "#left div.UcsGrid-cell.checkbox.head")

        if checkbox.find_element(By.CSS_SELECTOR, "ucs-checkbox").get_attribute("checked") is not None:
            # unselect and then reselect all
            self.click_element(checkbox, timeout)
        self.click_element(checkbox, timeout)

    def unselect_all(self, all_pages, timeout: int) -> None:
        """
            unselect all rows for current page table

            :param all_pages: whether to unselect all rowes in all page.
            :param timeout: time to wait for table to be loaded.
            :return: None
        """

        table_grid = self._get_table_grid(timeout)
        if not all_pages:
            checkbox = table_grid.find_element(
                By.CSS_SELECTOR, "#left div.UcsGrid-cell.checkbox.head")

            checkbox_element = checkbox.find_element(By.CSS_SELECTOR, "ucs-checkbox, ucs-radio")
            if checkbox_element.tag_name == "ucs-checkbox":
                if checkbox_element.get_attribute("checked") is None:
                    # we will click and unclick to unselect all
                    self.click_element(checkbox, timeout)
                self.click_element(checkbox, timeout)
            else:
                # radio button
                # button to unselect all for example, dashlet server details creation page.
                unselect_link = self.shadow_root_element(self.actual_element, "ucs-button[data-test-id='unselectAll']")
                self.click_element(unselect_link, timeout)
        else:
            # use unselect link to unselect entire table.
            unselect_link = self.shadow_root_element(self.actual_element, "ucs-button[data-test-id='unselectAll']")
            self.click_element(unselect_link, timeout)

    def show_selected(self, timeout: int) -> bool:
        """
            show only selected rows

            :param timeout: time to wait for table to be loaded.
            :return: True if show selected is clicked.  False if table already in show selected state
        """
        self._get_table_grid(timeout)
        show_selected_link = self.shadow_root_element(self.actual_element, "ucs-button[data-test-id='showSelected']")
        if show_selected_link is None:
            raise ValueNotFound("No row is selected.")

        if "display: none" not in show_selected_link.get_attribute("style"):
            self.click_element(show_selected_link, timeout)
            return True
        return False

    def show_all(self, timeout: int) -> bool:
        """
            show all rows

            :param timeout: time to wait for table to be loaded.
            :return: True if show all is clicked. False if table already in show all state
        """
        self._get_table_grid(timeout)
        show_buttons = self.shadow_root_elements(self.actual_element, "ucs-button[data-test-id='showAll']")
        if len(show_buttons) == 0:
            raise ValueNotFound("No row is selected.")

        # show all button only get created after show selected is clicked
        if show_buttons[-1].text == "Show All" and "display: none" not in show_buttons[-1].get_attribute("style"):
            self.click_element(show_buttons[-1], timeout)
            return True
        return False

    def get_matched_row_indices(self,
                                row_info_list: List[Mapping[str, Union[str, RePattern]]],
                                table_grid: Optional[WebElement] = None,
                                timeout: Optional[int] = None) -> List[int]:
        """
            return list of row index that match criteria in row_info_list.
            The row_info_list is list of criteria.  As long as the row match one of criteria, it will
            be considered as match.  The criteria is a dictioanry with column name as key and desired matching value.
            The matching value can be either string or regular expression

            For example:

            with row_info_list as [{Name: "abc"}, {Name: re.compile("^xyz[0-9]$")}],
            It will return any row with Name = "abc" or Name starts with xyz following by 1 number.

            :param row_info_list: list of matching criteria.
            :param table_grid: table grid web element.  Provide the argument to improve process time.
            :param timeout: time to wait for table to be loaded.

            :return: list of matched row indices.
        """
        if table_grid is None:
            table_grid = self._get_table_grid(timeout)

        table_data = self.page_data(None, table_grid=table_grid, timeout=timeout)

        rtr_list = []
        for row_index, data_map in enumerate(table_data):
            for row_info in row_info_list:
                for key, value in row_info.items():
                    data_value = data_map.get(key, None)
                    if data_value is None:
                        # key is not found
                        break
                    if isinstance(value, RePattern):
                        if not value.search(data_value):
                            # not match regex provided
                            break
                    elif value != data_value:
                        # value not match
                        break
                else:
                    # match all condition
                    rtr_list.append(row_index)
                    break
        return rtr_list

    def select_rows(self,
                    row_indices: List[int],
                    timeout: int) -> None:
        """
            select given row indices

            :param row_indices: row indcies to select.
            :param timeout: time to wait for table to be loaded.

            :return: None
        """

        table_grid = self._get_table_grid(timeout)

        checkbox_list = []
        for row_index in row_indices:
            checkbox = table_grid.find_element(
                By.CSS_SELECTOR, "#left div.UcsGrid-column.checkbox.body > div:nth-child({0})".format(row_index + 1))
            checkbox_list.append(checkbox)

        wait_time_gen = util.wait_time.generator(self.START_WAIT_TIME,
                                                 self.MAX_INTERVAL_TIME,
                                                 self.CONTEXT_WAIT_TIME)
        for i in wait_time_gen:
            clicked = False
            for checkbox in checkbox_list:
                if checkbox.find_element(By.CSS_SELECTOR, "ucs-checkbox, ucs-radio").get_attribute("checked") is None:
                    self.click_element(checkbox, timeout)
                    clicked = True
            else:
                if not clicked:
                    # no row is clicked, so we are done.
                    break
            time.sleep(i)
        else:
            raise ValueNotSet(f"Unable to select desired rows {row_indices}")

    def selected_rows(self,
                      timeout: int) -> List[int]:
        """
            return rows selected in current table page

            :param timeout: time to wait for table to be loaded.

            :return: list of rows selected
        """

        table_grid = self._get_table_grid(timeout)

        checkbox_list = table_grid.find_elements(By.CSS_SELECTOR,
                                                 "#left div.UcsGrid-column.checkbox.body > div")

        row_indices = []
        for index, checkbox in enumerate(checkbox_list):
            if "selected" in checkbox.get_attribute("class"):
                row_indices.append(index)

        return row_indices

