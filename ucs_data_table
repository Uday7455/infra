    def get_search_attributes(self, timeout: int) -> List[str]:
        """
            Click on filter and fetch all search attributes from dropdown
            :param timeout: time to wait for table to be loaded
            :return : List of search attributes
        """
        _ = self._get_table_grid(timeout)
        element = self.actual_element
        filter_widget_element = self.__get_filter_widget_element(element)
        filter_attributes = []
        if not filter_widget_element:
            ucs_tag_editor = self.shadow_root_element(
                element, "ucs-tag-editor")
            filter_element = self.shadow_root_element(
                element, "ucs-tag-editor#filterWidget")
            if not filter_element:
                raise ValueNotFound("Unable to find filter element.")
            self.click_element(filter_element, timeout)
            ucs_dropdown_menu = self.shadow_root_element(
                ucs_tag_editor, "div#tags-container > div#tags > div#tags-control > div#suggestions >ucs-dropdown-menu")
            values = ucs_dropdown_menu.find_elements(By.CSS_SELECTOR, "ucs-dropdown-option")
            filter_attributes = [self.get_text(i) for i in values]
            action_chains = ActionChains(self.driver)
            action_chains.send_keys(Keys.ESCAPE).perform()
        else:
            filter_drawer = self.shadow_root_element(
                filter_widget_element, "is-filter-drawer")
            if not filter_drawer:
                raise ValueNotFound("Unable to find filter drawer element.")
            filter_btn_elm = filter_drawer.find_element(
                By.CSS_SELECTOR, "[data-test-id^='table:filter-btn']")
            if not filter_btn_elm:
                raise ValueNotFound("Unable to find filter button.")

            filter_click_ctx = ButtonContext(filter_btn_elm, common_info=self.common_info)
            filter_click_ctx.click(timeout)
            filter_drawer_ctx = FilterDrawerFormPropertiesContext(filter_drawer, common_info=self.common_info)
            filter_attributes = list(filter(lambda list: list != "Tags", filter_drawer_ctx.values(timeout)))
        return filter_attributes

    def add_custom_tab(self, custom_name=None, timeout=None) -> None:
        """
        click on the plus button in table header

        :param custom_name: if custom_name is None ,default value will be saved else custom_name will be saved
        :param timeout: time to wait for table to be loaded.
        :return: None
        """
        _ = self._get_table_grid(timeout)
        element = self.actual_element
        table_header = self.shadow_root_element(element, "ucs-data-table-header")
        button = self.shadow_root_element(
            table_header, "ucs-icon.create-icon")
        if not button:
            raise ValueNotFound("Unable to find ucs plus icon element.")
        self.click_element(button, timeout)
        ucs_data_table_setting_element = self.shadow_root_element(element, "ucs-data-table-settings")
        ucs_modal_element = self.shadow_root_element(ucs_data_table_setting_element, "ucs-modal")
        # custom tab name
        name_element = ucs_modal_element.find_element(By.CSS_SELECTOR, "div.body ucs-input[ref='nameInput']")
        custom_name_input_ctx = UcsInputTextContext(name_element, common_info=self.common_info)
        if custom_name is not None:
            custom_name_input_ctx.input(custom_name, timeout)
        footer_buttons = ucs_modal_element.find_elements(By.CSS_SELECTOR, "div.footer ucs-button")
        for footer_button in footer_buttons:
            if footer_button.text == 'Add':
                self.click_element(footer_button, timeout)
                break
        self._wait_table_move_to_update()


class UcsDataTable(WebComponent):
    """
        ucs data table web component class definition

        url: table base component.  Use in many pages.  See unit test for specific page usage
    """

    @property
    def path_contexts(self) -> List[str]:
        """
            return path contexts of the web components

            :return: return path contexts of the web components.
        """
        return ["Table"]

    @property
    def click_context(self) -> ClickContextMap:
        """
            return path contexts of the web components
            :return: return path contexts of the web components.
        """
        if self._click_context is None:
            self._click_context = {}
            parent_context = self.parent_context_plus(self.path_contexts)
            setting = self.shadow_root_element(
                self.web_element,
                "ucs-icon[data-test-id^='table-column-settings'], ucs-button#settingsButton"
            )
            if setting:
                self._click_context["icon:setting"] = {
                    parent_context: ButtonContext(setting, common_info=self.common_info)}

            export_btn = self.shadow_root_element(
                self.web_element,
                "ucs-button[data-action='export'], ucs-button.GridHeader-export"
            )
            if export_btn:
                self._click_context["icon:export"] = {
                    parent_context: ButtonContext(export_btn, common_info=self.common_info)}

            expand_btn = self.shadow_root_element(
                self.web_element, "ucs-button[data-test-id='expandAllButton']")
            if expand_btn is not None:
                label = self.get_text(expand_btn)
                self._click_context[label] = {
                    parent_context: ButtonContext(
                        expand_btn, common_info=self.common_info)}
        return self._click_context

    @property
    def table_context(self) -> Mapping[str, Mapping[str, TableContext]]:
        """
            return available select context
            :return: select context dictionary.
        """
        if self._table_context is None:
            if "hidden" in self.web_element.get_attribute("class"):
                # hidden table
                self._table_context = {}
            else:
                if self.parent_context:
                    context, parent_context = self.parent_context_as_name
                else:
                    context = self.parent_context
                    parent_context = None
                self._table_context = {
                    context: {parent_context: DataTableContext(self.web_element, common_info=self.common_info)}}
        return self._table_context

    def handle_child_components(self, element: WebElement) -> ChildComponentsInfo:
        """
            custom child components information to component manager.

            :param element: reference web element
            :return: custom child components information
        """
        # pass header, widget, header pop up for further processing.
        widget_elements = self.shadow_root_elements(element, "ucs-model-crud-attention-widget,"
                                                             "ucs-data-table-header,"
                                                             "ucs-data-table-settings,"
                                                             "[data-test-id^='filter-widget']")
        return ChildComponentsInfo(widget_elements)
