    def set_filter(self,
                   filter_str: Union[str, List[Union[str, Dict]], Dict],
                   timeout: int) -> None:
        """
            set table filter

            :param filter_str: filter string to set
            :param timeout: time to wait for table to be loaded.

            :return: None
        """
        # Wait for table to load first
        _ = self._get_table_grid(timeout)
        element = self.actual_element
        filter_widget_element = self.__get_filter_widget_element(element)
        if not filter_widget_element:
            filter_element = self.__get_legacy_tag_editor_element(element)
            if not filter_element:
                raise ValueNotFound("Unable to find filter element.")
            input_ctx = UcsTagEditorContext(
                filter_element, common_info=self.common_info)
            input_ctx.input(filter_str, timeout)
        else:
            if self.__is_free_form_search(filter_str):
                self.set_search_input(filter_str, timeout, filter_widget_element)
            else:
                filter_dict = self.__get_filter_dict(filter_str)
                filter_drawer = self.shadow_root_element(
                    filter_widget_element, "is-filter-drawer")
                if not filter_drawer:
                    raise ValueNotFound("Unable to find filter drawer element.")
                filter_btn_elm = filter_drawer.find_element(
                    By.CSS_SELECTOR, "[data-test-id^='table:filter-btn']")
                if not filter_btn_elm:
                    raise ValueNotFound("Unable to find filter button.")

                filter_click_ctx = ButtonContext(filter_btn_elm, common_info=self.common_info)
                filter_click_ctx.click(timeout)
                filter_drawer_ctx = FilterDrawerInputContext(filter_drawer, common_info=self.common_info)
                filter_drawer_ctx.input(filter_dict, timeout)

        self._wait_table_move_to_update()
        self.wait_table_loaded(timeout)

    def clear_filter(self,
                     timeout: int,
                     use_button: Optional[bool] = False) -> None:
        """
            clear table filter

            :param timeout: time to wait for table to be loaded.
            :param use_button: if True, use the 'X' button to clear filter.

            :return: None
        """
        element = self.actual_element
        filter_widget_element = self.__get_filter_widget_element(element)
        if not filter_widget_element:
            if use_button:
                filter_element = self.__get_legacy_tag_editor_element(element)
                if not filter_element:
                    raise ValueNotFound("Unable to find filter element.")

                clear_button_elem = self.shadow_root_element(filter_element, "div.Tags-clear > ucs-button")
                if not clear_button_elem:
                    raise ValueNotFound("Unable to find clear filter button.")
                clear_button = ButtonContext(clear_button_elem, common_info=self.common_info)
                clear_button.click(timeout=timeout)
                # After clicking on the button, we send an empty filter to close the dropdown that follows

            self.set_filter("", timeout)
        else:
            if self.get_search_input(timeout, filter_widget_element):
                self.set_search_input("", timeout, filter_widget_element)
            if len(self.get_filter(timeout)) > 0:
                reset_button = self.shadow_root_element(filter_widget_element, "[data-test-id^='table:reset-all']")
                if not reset_button:
                    raise ValueNotFound("Unable to find reset button.")
                reset_button_ctx = ButtonContext(reset_button, common_info=self.common_info)
                reset_button_ctx.click(timeout)
                time.sleep(1)

    def get_filter(self,
                   timeout: int, dict_list: Optional[bool] = False) -> List[Union[str, Dict]]:
        """
            get table filter current set to

            :param timeout: time to wait for table to be loaded.

