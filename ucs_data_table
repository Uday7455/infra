    def action_on_selected(self,
                           action: str,
                           use_footer: bool,
                           timeout: int) -> None:
        """
            perform given action on selected row of the table

            :param action: action to perform on selected row.  Possible value can be found using
                           self.action_on_selected_choices method
            :param use_footer: If True, trigger action from the bottom of the table.  Otherwise,
                               trigger from the top of the table.
            :param timeout: time to wait for table to be loaded.

            :return: None
        """
        # make sure table is loaded
        _ = self._get_table_grid(timeout)

        element = self.actual_element

        if not use_footer:
            actions = self.shadow_root_element(
                element, "div.GridHeader-actions")
            if not actions:
                raise ValueNotFound("Unable to table header action element.")
            try:
                actions_panel = actions.find_element(
                    By.CSS_SELECTOR, "ucs-actions-panel")
                actions = actions_panel
            except exceptions.NoSuchElementException:
                pass
        else:
            actions = self.shadow_root_element(
                element, "div.GridFooter-actions, div.GridFooter > ucs-actions-panel")
            if not actions:
                raise ValueNotFound("Unable to table footer action element.")

        if actions.tag_name == "ucs-actions-panel":
            elements = self.shadow_root_elements(actions, "ucs-button")
        else:
            elements = actions.find_elements(By.CSS_SELECTOR, "ucs-button")

        for element in elements:
            choice = re.sub("^ucs:(isnd-)?", "icon:", element.get_attribute("icon"))
            if not choice:
                choice = element.get_attribute("title")
            if choice == action:
                self.click_element(element, timeout)
                return

        if actions.tag_name == "ucs-actions-panel":
            elements = self.shadow_root_elements(
                actions, "ucs-dropdown-pro-max")
        else:
            elements = actions.find_elements(
                By.CSS_SELECTOR, "ucs-dropdown-pro-max")

        if elements:
            assert len(elements) == 1
            select_ctx = UcsDropdownProMaxContext(
                elements[0], common_info=self.common_info)
            select_ctx.select(action, timeout)
            return

        raise ValueNotSet("Unable to find action {0}.  Available actions are {1}".format(
            action, self.action_on_selected_choices(use_footer, None, timeout)))

    def action_on_selected_choices(self,
                                   use_footer: bool,
                                   enabled: Optional[bool],
                                   timeout: int) -> List[str]:
        """
            return action choices on selected row of the table

            :param use_footer: If True, trigger action from the bottom of the table.  Otherwise,
                               trigger from the top of the table.
            :param enabled: if None, return all choices.  If True, return enabled choice only.  If False,
                            return disabled choice only.
            :param timeout: time to wait for table to be loaded.
            :return: list of possible action choices
        """

        # make sure table is loaded
        _ = self._get_table_grid(timeout)

        element = self.actual_element
        if not use_footer:
            actions = self.shadow_root_element(
                element, "div.GridHeader-actions")
            if not actions:
                raise ValueNotFound("Unable to table header action element.")

            try:
                actions_panel = actions.find_element(
                    By.CSS_SELECTOR, "ucs-actions-panel")
                actions = actions_panel
            except exceptions.NoSuchElementException:
                pass

        else:
            actions = self.shadow_root_element(
                element, "div.GridFooter-actions, ucs-actions-panel")
            if not actions:
                raise ValueNotFound("Unable to table footer action element.")

        choices = []

        if actions.tag_name == "ucs-actions-panel":
            elements = self.shadow_root_elements(
                actions, "ucs-dropdown-pro-max")
        else:
            elements = actions.find_elements(
                By.CSS_SELECTOR, "ucs-dropdown-pro-max")
        exclude_buttons = set()
        if elements:
            assert len(elements) == 1
            exclude_buttons = set(
                map(lambda x: x.id, elements[0].find_elements(By.CSS_SELECTOR, "ucs-button")))
            select_ctx = UcsDropdownProMaxContext(
                elements[0], common_info=self.common_info)
            choices.extend(select_ctx.choices(enabled, timeout))

        if actions.tag_name == "ucs-actions-panel":
            elements = self.shadow_root_elements(actions, "ucs-button")
        else:
            elements = actions.find_elements(By.CSS_SELECTOR, "ucs-button")

        for element in elements:
            if element.id not in exclude_buttons:
                button_enabled = element.get_attribute("disabled") is None
                if enabled is None or enabled == button_enabled:
                    choice = re.sub("^ucs:(isnd-)?", "icon:", element.get_attribute("icon"))
                    if not choice:
                        choice = element.get_attribute("title")

                    choices.append(choice)

        return choices

    def items_found(self, timeout: int) -> int:
        """
            return items found for the table

            :param timeout: time to wait for table to be loaded.
            :return: items found for the table
        """

        # make sure table is loaded
        _ = self._get_table_grid(timeout)
        element = self.actual_element
        filter_widget_element = self.__get_filter_widget_element(element)
        if not filter_widget_element:
            item_found = self.shadow_root_element(
                element, "div:not([hidden]).GridHeader "
                "div.GridHeader-pagination-details")
            if not item_found:
                # check if pagination is hidden.  If yes, return 1
                if self.shadow_root_element(element, "div.GridHeader[hidden] div.GridHeader-pagination, "
                                            "div.GridHeader-pagination[hidden]") is not None:
                    # pagination is hidden, so find number of rows by query current page data.
                    # find number of rows
                    return len(self.page_data(timeout=timeout))
                raise ValueNotFound("Unable to find items found element.")
        else:
            # TO-DO: change it to data test id selector
            item_found = self.shadow_root_element(filter_widget_element, "div.filter-widget span.total-count")
            if not item_found:
                raise ValueNotFound("Unable to find items found element.")

        return int(re.search("[0-9]+", item_found.text).group())

    def items_selected(self, timeout: int) -> Optional[int]:
        """
            return items selected for the table

            :param timeout: time to wait for table to be loaded.
            :return: items selected for the table
        """

        # make sure table is loaded
        _ = self._get_table_grid(timeout)
        element = self.actual_element
        selected = self.shadow_root_element(element, "div[data-test-id='toolbarSelected']")
        if selected:
            if "display: none" in selected.get_attribute("style"):
                # hidden, so return 0
                return None
            text = selected.find_element(By.CSS_SELECTOR, "span[data-test-id='selectedCount']").text
            return int(re.search("([0-9]+)", text).group(1))

        return None

    def per_page(self, timeout: int) -> int:
        """
            return item per page for the table

            :param timeout: time to wait for table to be loaded.
            :return: item per page for the table
        """

        # make sure table is loaded
        _ = self._get_table_grid(timeout)
        pagination_ctx = self._get_pagination_context()
        return pagination_ctx.get_per_page(timeout)

    def set_per_page(self, page_size: Union[str, int], timeout: int) -> None:
        """
            set item per page for the table

            :param page_size: item per page to be set
            :param timeout: time to wait for table to be loaded.
            :return: None
        """
        _ = self._get_table_grid(timeout)
        data = self.page_data(timeout=timeout)
        if len(data) == 0:
            self.common_info.log("Table is empty. Skipping set_per_page action")
            return
        pagination_ctx = self._get_pagination_context()
        pagination_ctx.set_per_page(page_size, timeout)

        self._wait_table_move_to_update()

    def per_page_choices(self, enabled: Optional[bool], timeout: int) -> List[str]:
        """
            return item per page choices for the table

            :param enabled: if None, return all choices.  If True, return enabled choice only.  If False,
                            return disabled choice only.
            :param timeout: time to wait for table to be loaded.
            :return: item per page choices
        """

        if enabled is False:
            return []
        _ = self._get_table_grid(timeout)

        pagination_ctx = self._get_pagination_context()
        return pagination_ctx.get_per_page_choices(enabled, timeout)

    def first_page(self, timeout: int) -> None:
        """
            go to first page of the table

            :param timeout: time to wait for table to be loaded.
            :return: None
        """
        _ = self._get_table_grid(timeout)

        pagination_ctx = self._get_pagination_context()
        pagination_ctx.first_page(timeout)
        self._wait_table_move_to_update()

    def previous_page(self, timeout: int) -> None:
        """
            go to previous page of the table

            :param timeout: time to wait for table to be loaded.
            :return: None
        """

        _ = self._get_table_grid(timeout)
        pagination_ctx = self._get_pagination_context()
        pagination_ctx.previous_page(timeout)
        self._wait_table_move_to_update()

    def page_number(self, timeout: int) -> int:
        """
            return current page number of the table

            :param timeout: time to wait for table to be loaded.
            :return: current page number of the table
        """
        _ = self._get_table_grid(timeout)
        pagination_ctx = self._get_pagination_context()
        page_number = pagination_ctx.get_selected_page_number()
        if not page_number:
            if pagination_ctx.is_hidden() is not None:
                # pagination is hidden, just return 1
                return 1
            # if we have 0 items in table
            if self.items_found(timeout) == 0:
                return 0
            raise ValueNotFound("Unable to find page number element.")

        # value = self.get_text(selected_page_element)
        return page_number

