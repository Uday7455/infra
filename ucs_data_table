class DataTableContext(TableContext):
    """
        Data table context class definition
    """

    ORDER_STR = [None, "ascent", "descent", "asc", "desc"]

    def _get_pagination_context(self) -> Optional[UcsPaginationContext]:
        element = self.actual_element
        pagination = self.shadow_root_element(element, "ucs-pagination")
        if not pagination:
            return None
        return UcsPaginationContext(pagination, common_info=self.common_info)

    def _get_table_grid(self, timeout: int) -> WebElement:
        """
            return table data grid web element

            :param timeout: time to wait for table to be loaded.
            :return: table data grid web element

        """

        element = self.actual_element
        wait_time_gen = util.wait_time.generator(self.START_WAIT_TIME,
                                                 self.MAX_INTERVAL_TIME,
                                                 timeout)

        for i in wait_time_gen:
            table_grid = self.shadow_root_element(
                element, "div#container > div.UcsGrid[state='idle']")
            if table_grid:
                break
            time.sleep(i)
        else:
            raise exceptions.NoSuchElementException("Not able to find element with locator"
                                                    " div#container > div.UcsGrid[state='idle']")

        return table_grid

    def wait_table_loaded(self, timeout: int) -> None:
        """
            return wait until table is loaded

            :param timeout: time to wait for table to be loaded.
            :return: None

        """
        self._get_table_grid(timeout)

    def _wait_table_move_to_update(self, timeout: float = 1.1) -> None:
        """
            wait for table to move to update state

            :param timeout: time to wait for table to move to update state.
                timeout in the product is 1 second for table to move to update,
                aligning the timeout with the product, with a 0.1-second buffer.

        """

        element = self.actual_element
        wait_time_gen = util.wait_time.generator(self.START_WAIT_TIME,
                                                 self.MAX_INTERVAL_TIME,
                                                 timeout)

        for i in wait_time_gen:
            table_grid = self.shadow_root_element(
                element, "div#container > div.UcsGrid[state='update']")
            if table_grid:
                break
            time.sleep(i)

    def _is_hierarchical_table(self) -> bool:
        """
        Detect hierarchical ucs-data-table by host id matching hierarchicalTable.

        :return: True if hierarchical tree table, else False.
        """
        host = self.actual_element
        el_id = (host.get_attribute("id") or "").strip().lower()
        return el_id == "hierarchicaltable"

    def _has_unread_flag(self) -> bool:
        """
        Detect if table supports unread/read advisory status.

        :return: True when host carries the data-has-unread attribute, else False.
        """
        host = self.actual_element
        return host.get_attribute("data-has-unread") is not None

    def _get_matched_column(self,
                            column: Optional[str] = None,
                            table_grid: Optional[WebElement] = None,
                            timeout: Optional[int] = None) -> Tuple[int, WebElement]:
        """
            return column index and column web element that matched given column

            :param column: column name to match
            :param table_grid: table grid web element.
            :param timeout: time to wait for table to be loaded.

            :return: table grid web element

        """

        if table_grid is None:
            table_grid = self._get_table_grid(timeout)

        elements = table_grid.find_elements(
            By.CSS_SELECTOR, "div#main div.UcsGrid-column.head")

        # workaround for remove group element
        elements = [ele for ele in elements if ele.get_attribute('class') != 'UcsGrid-column group head']

        for index, element in enumerate(elements):
            if column == element.text:
                return index, element

        raise ValueNotFound("Unable to find column {0}.  Available columns are {1}".format(
            column, list(map(lambda x: x.text, elements))))

    def __remove_start_end_quotes(self, text: str = "") -> str:
        return re.sub(r"^(['\"])(.*)\1$", r"\2", text)

