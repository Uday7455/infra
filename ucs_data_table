    def click_cell(self,
                   row_index: int,
                   column: str,
                   timeout: int) -> None:
        """
            click table cell for given row index and column

            :param row_index: row index of the table cell
            :param column: column name of the table cell
            :param timeout: time to wait for table to be loaded.

            :return: None
        """

        table_grid = self._get_table_grid(timeout)

        column_index, _ = self._get_matched_column(column, table_grid, timeout)

        cell = table_grid.find_element(
            By.CSS_SELECTOR,
            "div#main div.UcsGrid-column.body:nth-child({0}) div.UcsGrid-cell.body:nth-child({1})".format(
                column_index + 1, row_index + 1))

        # check if there ucs-link, if yes, click on the link vs cell, since middle of cell may not be the link
        try:
            element = cell.find_element(
                By.CSS_SELECTOR,
                "ucs-link, div.renderer-hyper-link, div.u-link, ucs-icon.renderer-hyper-link, ucs-button")
        except exceptions.NoSuchElementException:
            element = cell

        self.click_element(element, timeout)

    def click_row_tree_toggle(self,
                              row_index: int,
                              timeout: int,
                              expand: Optional[bool] = None) -> None:
        """
        Click the hierarchical table row tree caret (ucs:down-arrow in the first column).

        :param row_index: visible row index in the first column (same as page_data).
        :param timeout: seconds to wait for grid idle after the click.
        :param expand: if True, click only when collapsed; if False, only when expanded;
            if None, always click once (toggle).
        :return: None.
        :raises ValueNotFound: missing grid, bad row index, or row has no caret.
        """
        table_grid = self._get_table_grid(timeout)
        table_body = table_grid.find_element(
            By.CSS_SELECTOR, "div#main > div.UcsGrid-body")
        hierarchical = self._is_hierarchical_table()
        raw = util.get_table_tree_toggle(
            self.driver, table_body, hierarchical, row_index)
        icon_el, visible_count, code = raw[0], raw[1], raw[2]
        expanded: Optional[bool] = None
        if len(raw) > 3:
            expanded = raw[3]  # True / False / null from script
        if code == "no_columns":
            raise ValueNotFound("Unable to find grid columns in table body.")
        if code == "bad_index":
            raise ValueNotFound(
                "Row index {0} is out of range for visible rows (count={1}).".format(
                    row_index, visible_count))
        if code == "no_icon":
            raise ValueNotFound(
                "No ucs:down-arrow tree caret on visible row {0}.".format(row_index))
        if expand is not None and expanded is not None:
            want_open = bool(expand)
            if want_open and expanded:
                return
            if not want_open and not expanded:
                return
        click_ctx = ButtonContext(icon_el, common_info=self.common_info)
        click_ctx.click(timeout)
        self._get_table_grid(timeout)

    def hover_cell(self,
                   row_index: int,
                   column: str,
                   timeout: int) -> str:
        """
            Get hover data for a cell of a given row index and column

            :param row_index: row index of the table cell
            :param column: column name of the table cell
            :param timeout: time to wait for table to be loaded.

            :return: None
        """

        table_grid = self._get_table_grid(timeout)

        column_index, _ = self._get_matched_column(column, table_grid, timeout)

        cell = table_grid.find_element(
            By.CSS_SELECTOR,
            "div#main div.UcsGrid-column.body:nth-child({0}) div.UcsGrid-cell.body:nth-child({1})".format(
                column_index + 1, row_index + 1))

        # check for ucs-tooltip-host's
        # For Tags we can have multiple ucs-tooltip-host -> STARSHIP-11423
        elements = cell.find_elements(By.CSS_SELECTOR, "ucs-tooltip-host")

        # If ucs-tooltip-host is not present we will get empty list
        # In that case lets keep the cell element
        if not elements:
            elements = [cell]

        hover_strings = []
        for element in elements:
            ucs_tooltip_host_component = UcsTooltipHostContext(element=element)
            hover_strings.append(ucs_tooltip_host_component.details(timeout=timeout))
        return ",".join(hover_strings)

    def action_on_row(self,
                      action: str,
                      row_index: int,
                      timeout: int,
                      hover: Optional[bool] = False) -> None:
        """
            perform given action for given row of table

            :param action: action to perform on the table row.  Possible value can be found using
                           self.action_on_row_choices method
            :param row_index: row index to perform the action on
            :param timeout: time to wait for table to be loaded.
            :param hover: to hover over the action element

            :return: None
        """

        table_grid = self._get_table_grid(timeout)
        wait_time_gen = util.wait_time.generator(self.START_WAIT_TIME,
                                                 self.MAX_INTERVAL_TIME,
                                                 self.CONTEXT_WAIT_TIME)
        exception = None
        for wait_time in wait_time_gen:
            self.common_info.log("trying to find the ucs-dropdown-pro-max element")
            dropdown_element = None
            button_element = None
            icon_element = None
            try:
                dropdown_element = table_grid.find_element(
                    By.CSS_SELECTOR, "div#right div.UcsGrid-cell.body:nth-child({0}) > ucs-dropdown-pro-max".
                    format(row_index + 1))
                self.common_info.log("found the ucs-dropdown-pro-max element!")
                break
            except exceptions.NoSuchElementException as exc:
                exception = exc
                try:
                    self.common_info.log("ucs-dropdown-pro-max element not found in this attempt")
                    self.common_info.log("Checking if ucs-button element is present (single button in actions)")
                    icon_element = table_grid.find_element(
                        By.CSS_SELECTOR,
                        "div#right div.UcsGrid-cell.body:nth-child({0}) > ucs-button:not([icon='ucs:more'])".
                        format(row_index + 1))
                    break
                except exceptions.NoSuchElementException as nse:
                    self.common_info.log("ucs-button element not found in this attempt")
                    exception = nse

            try:
                button_element = table_grid.find_element(
                    By.CSS_SELECTOR, "div#right div.UcsGrid-cell.body:nth-child({0}) > ucs-button".
                    format(row_index + 1))
                self.common_info.log("found the ucs-button element!")
                action_chains = ActionChains(self.driver)
                action_chains.move_to_element(button_element).perform()
            except exceptions.NoSuchElementException as exc:
                self.common_info.log("ucs-button element not found in this attempt")
                exception = exc

            time.sleep(wait_time)
        else:
            raise exception

        if dropdown_element:
            select_ctx = UcsDropdownProMaxContext(
                dropdown_element, common_info=self.common_info)
            self.common_info.log("selecting the ucs-dropdown-pro-max element!")
            if hover:
                return select_ctx.get_choice_tooltip(action, timeout)

            select_ctx.select(action, timeout)
            self.common_info.log("select passed!")

        if button_element or icon_element:
            if button_element:
                element_to_click = button_element
            else:
                element_to_click = icon_element
            # This means only a single action is available
            click_ctx = ButtonContext(element_to_click, common_info=self.common_info)
            click_ctx.click(timeout)
            self.common_info.log("button clicked!")

    def action_on_row_choices(self,
                              row_index: int,
                              enabled: Optional[bool],
